#include<iostream>
using namespace std;

enum State{
    OK,
    DIV0,
    OUT_OF_BOUNDS
};

class myInt{
    public:
        int value;
        
        myInt(int v=0){
            this->value=v;
        }
        
        myInt add(myInt*a){
            return myInt(this->value+a->value);
        }
        
        myInt sub(myInt*a){
            return myInt(this->value-a->value);
        }
        
        myInt mul(myInt*a){
            return myInt(this->value*a->value);
        }
        
        myInt divide(myInt*a){
            return myInt(this->value/a->value);
        }
        
        myInt power(myInt*a){
            int temp=1, i=0;
            for(i=0;i<a->value;i++){
                temp=temp*this->value;
            }
            return myInt(temp);
        }
};

class myReal{
    public:
        float val;
};

class calc{
    public:
        int state;
        myInt result;
        
        calc(myInt*a,myInt*b,char op){
            this->state=0;
        
        
        switch(op){
            case '+':
            this->result=a->add(b); break;
            case '-':
            this->result=a->sub(b); break;
            case '*':
            this->result=a->mul(b); break;
            case '/':
            if(b->value==0){
                this->state=1;
            }
            else{
                this->result=a->divide(b);
            } break;
            case '^':
            if(b->value<0){
                this->state=2;
            }
            else{
                this->result=a->power(b);
            } break;
            
            default:
            this->state=3; break;
        }
    }
};

