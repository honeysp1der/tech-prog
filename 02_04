#include<iostream>
using namespace std;

int main(){
    int a,b,wynik,state;
    char op;
    state=0;
    
    cout<<"Podaj pierwsza liczbe: "<<endl;
    cin>>a;
    cout<<"Podaj druga liczbe: "<<endl;
    cin>>b;
    cout<<"Jaka operacje chcesz wykonac? (+,-,*,/)"<<endl;
    cin>>op;
    
    switch (op)
    {
        case '+': wynik=a+b; break;
        case '-': wynik=a-b; break;
        case '*': wynik=a*b; break;
        case '/':
        if(b==0){
            state=1;
        }
            else {
                wynik=a/b; break;
        }
        default: state=2; break;
    }
    
    if(state==0){
        cout<<"Wynik: "<<wynik<<endl;
    }else if(state==1){
        cout<<"Blad: nie mozna podzielic przez 0."<<endl;
    }else{
        cout<<"Blad: nie ma takiego znaku."<<endl;
    }
 return 0;
}
